def get_okved_risks(okved_code):
    code_prefix = okved_code.split('.')[0][:2]
    sections = {
        "01": "Сельское, лесное хозяйство, охота, рыболовство",
        "10": "Производство пищевых продуктов",
        "11": "Производство напитков",
